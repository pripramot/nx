{
  "name": "tauri-opener",
  "projectType": "library",
  "sourceRoot": "packages/tauri-opener/src",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "options": {
        "outputPath": "dist/packages/tauri-opener",
        "tsConfig": "packages/tauri-opener/tsconfig.json",
        "main": "packages/tauri-opener/src/index.ts"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "packages/tauri-opener/jest.config.cts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/tauri-opener/**/*.ts"]
      }
    }
  },
  "tags": []
}
